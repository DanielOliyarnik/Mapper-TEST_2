{
  "use_template_features": true,
  "match_fields": [
    "key",
    "label",
    "role",
    "unit",
    "location",
    "hierarchy",
    "zone_id",
    "loop_ids",
    "group_id",
    "equip_id",
    "class",
    "brick_class"
  ],
  "list_joiner": "|",
  "on_feature_error": "raise",
  "features": [],
  "force_retrain": true,
  "write_features_info": true,
  "align_for_train": {
    "resample_freq": "15min",
    "ffill_limit_minutes": 60,
    "bounds": {
      "lo": null,
      "hi": null
    }
  }
}
